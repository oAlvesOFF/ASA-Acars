{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FlyAzoresACARS",
  "version": "0.7.8",
  "identifier": "com.flyazoresacars.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "FlyAzoresACARS",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "crates/sim-msfs/ffi/lib/SimConnect.dll": "SimConnect.dll"
    },
    "createUpdaterArtifacts": true,
    "publisher": "FlyAzoresACARS Project",
    "shortDescription": "Cross-platform ACARS client for phpVMS 7",
    "longDescription": "FlyAzoresACARS connects phpVMS 7 with MSFS 2020/2024 and X-Plane 11/12, recording flights, streaming live position data, and submitting full PIREPs with detailed runway and landing analysis."
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/oAlvesOFF/FlyAcars/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDREM0E0NzUxQzBGOTg0MDgKUldRSWhQbkFVVWM2VFFnMzJqRTVtM0pvQ285QTJPbFJBRWtIMXdUR3BDRkdtQWFFbm5lZzNiM2kK"
    }
  }
}
